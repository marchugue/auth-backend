NODE_ENV=development
PORT=5000

# --- PostgreSQL (used by Prisma) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auth_db?schema=public"

# --- JWT ---
# Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_REFRESH_EXPIRY=7d
REFRESH_TOKEN_COOKIE_NAME=refresh_token

# --- Frontend / links embedded in emails ---
CLIENT_URL=http://localhost:3000

# --- SMTP (leave blank in dev — emails will be logged to the console instead) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="No Reply <no-reply@example.com>"

# --- Behavior flags ---
# If true, users must verify their email before they can log in.
REQUIRE_EMAIL_VERIFICATION=false
