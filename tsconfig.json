{
  "compilerOptions": {
    "target": "ES2021",
    "module": "node16",
    "lib": ["ES2021"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node16",
    "declaration": false,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["app.ts", "server.ts", "app/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
